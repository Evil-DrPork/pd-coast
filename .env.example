# Poker44 miner configuration (example)
# Copy to `.env` and adjust:  cp .env.example .env
# Loaded by neurons/miner.py via python-dotenv.
# NOTE: Bittensor wallet / netuid / axon / subtensor are passed as CLI flags
# (see the run command at the bottom), NOT through this file.

# ─── Model artifact ───────────────────────────────────────────────────────────
# Path to the trained v2 artifact (encoder + XGBoost head + embedded calibrator).
P44_MODEL_PATH=detection_model/artifacts/p44_hier_xgb_cal.pt
# Optional external XGBoost .joblib. Leave blank — v2 artifacts embed XGBoost.
P44_XGB_PATH=

# ─── Inference windowing (MUST match how you trained) ─────────────────────────
# window_hands must be <= the model's max_hands or hands get truncated.
P44_WINDOW_HANDS=20
P44_WINDOW_STRIDE=10
# Aggregation of per-window scores: mean (recommended, FPR-safe) | max | min | topk_mean
P44_WINDOW_AGG=mean

# ─── Runtime ──────────────────────────────────────────────────────────────────
P44_MODEL_DEVICE=cpu
P44_INFERENCE_BATCH_SIZE=64
# Ignored when the artifact embeds a calibrator (boundary is already at 0.5).
P44_PREDICTION_THRESHOLD=0.5

# ─── Transparency manifest (optional; sane defaults exist) ────────────────────
P44_MANIFEST_MODEL_NAME=p44-hier-xgb-cal
P44_MANIFEST_MODEL_VERSION=2.0.0
P44_MANIFEST_FRAMEWORK=pytorch-hierarchical-transformer-xgboost
P44_MANIFEST_LICENSE=MIT
# repo_url + repo_commit are AUTO-DERIVED from `git` at startup (origin remote +
# HEAD), so the manifest is `transparent`-compliant out of the box when run from
# a git checkout. Only set these to override the detected values (e.g. running
# from a non-git deploy, or to pin a published commit).
P44_MANIFEST_REPO_URL=
P44_MANIFEST_REPO_COMMIT=
P44_MANIFEST_ARTIFACT_URL=
P44_MANIFEST_MODEL_CARD_URL=
# Leave blank to auto-compute the sha256 of P44_MODEL_PATH at startup.
P44_MANIFEST_ARTIFACT_SHA256=
POKER44_MODEL_ARTIFACT_SHA256=

# ─── Run command (wallet/netuid/axon are CLI flags, not env) ──────────────────
# python neurons/miner.py \
#   --netuid <NETUID> \
#   --subtensor.network finney \
#   --wallet.name <coldkey> --wallet.hotkey <hotkey> \
#   --axon.port <PORT> \
#   --logging.debug
